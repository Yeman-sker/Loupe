{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "npx -y @loupe-server/server ensure --port 7373",
            "timeout": 8,
            "async": true,
            "statusMessage": "Starting Loupe daemon"
          }
        ]
      }
    ]
  }
}
