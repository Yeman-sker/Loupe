{
  "manifest_version": 3,
  "name": "Loupe",
  "version": "0.0.0",
  "description": "Loupe Phase 0 placeholder extension.",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1/*", "http://localhost/*"],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["http://127.0.0.1/*", "http://localhost/*"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ]
}
